<% content_for :style do %>
  <!-- CSS only -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
  <!-- JavaScript Bundle with Popper -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
<% end %>
<div class="container">
  <p> Try paginating under context-1. Now try paginating in context-2. Notice how the context is maintained as you paginate between different contexts?</p>

  <h3> Context 1</h3>
  <%= turbo_frame_tag "context-1" do %>
    <% if @movies.any? %>
      <%= render "movies_table", locals: {movies: @movies}%>
    <% end %>
  <% end %>

  <h3> Context 2</h3>  
  <%= turbo_frame_tag "context-2", src: bootstrap_movies_path do %>
    <% if @movies.any? %>
      <%= render "movies_table", locals: {movies: @movies}%>
    <% end %>
  <% end %>   
</div>